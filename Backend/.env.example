# AWS (required for CDK deploy)
CDK_DEFAULT_ACCOUNT=          # aws sts get-caller-identity --query Account --output text
CDK_DEFAULT_REGION=us-east-1

# Frontend URL (required — used for CORS and email links)
FRONTEND_URL=https://rivalscan.com

# SES sender email (must be verified in AWS SES console)
FROM_EMAIL=noreply@rivalscan.com

# Paddle price IDs (from Paddle Dashboard > Catalog > Prices)
PADDLE_PRICE_SCOUT=pri_xxxxxxxxxxxxxxxxxxxx
PADDLE_PRICE_STRATEGIST=pri_xxxxxxxxxxxxxxxxxxxx
PADDLE_PRICE_COMMAND=pri_xxxxxxxxxxxxxxxxxxxx

# Stored in AWS Secrets Manager under "rivalscan/api-keys" (JSON):
# {
#   "PADDLE_SECRET_KEY": "...",       # Paddle Dashboard > Developer > Authentication
#   "PADDLE_WEBHOOK_SECRET": "...",   # Paddle Dashboard > Developer > Notifications
#   "FIRECRAWL_API_KEY": "...",       # firecrawl.dev
#   "ANTHROPIC_API_KEY": "..."        # console.anthropic.com
# }
